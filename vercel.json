{
  "version": 2,
  "builds": [
    {
      "src": "api/create-payment-intent.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/create-payment-intent",
      "dest": "/api/create-payment-intent.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
